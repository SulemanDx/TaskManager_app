# Comportamento predefinito: Git decide se un file è di testo e lo normalizza
* text=auto

# Web / Frontend: Forza LF per coerenza nel rendering e negli strumenti di build
*.html text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf

# Node.js / Backend: Cruciale per file di configurazione e lock
*.json text eol=lf
package.json text eol=lf
package-lock.json text eol=lf
.env* text eol=lf

# Documentazione e Config
*.md   text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf